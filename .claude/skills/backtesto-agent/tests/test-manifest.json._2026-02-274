{
  "description": "E2E validation manifest for backtesto-agent reports",
  "version": "1.0.0",
  "referenceReport": {
    "path": "docs/reports/test-portfolio-benchmark-2026-02-27.md",
    "fixture": "tests/fixtures/test-portfolio.json",
    "validated": "2026-02-27",
    "checks": 63,
    "images": 20
  },
  "checks": [
    {
      "id": "title",
      "check": "section_exists",
      "pattern": "^# Backtest Report:",
      "required": true
    },
    {
      "id": "date",
      "check": "section_exists",
      "pattern": "\\*\\*Date\\*\\*:\\s*\\d{4}-\\d{2}-\\d{2}",
      "required": true
    },
    {
      "id": "source",
      "check": "section_exists",
      "pattern": "\\*\\*Source\\*\\*:.*backtes\\.to",
      "required": true
    },

    {
      "id": "allocation-section",
      "check": "section_exists",
      "pattern": "^## Portfolio Allocation",
      "required": true
    },
    {
      "id": "allocation-table",
      "check": "table_has_columns",
      "section": "Portfolio Allocation",
      "columns": ["Asset", "ISIN"],
      "minRows": 1,
      "required": true
    },

    {
      "id": "settings-section",
      "check": "section_exists",
      "pattern": "^## Settings",
      "required": true
    },
    {
      "id": "settings-fields",
      "check": "has_bullet_fields",
      "section": "Settings",
      "fields": ["Period", "Initial investment", "Recurring", "Rebalancing"],
      "required": true
    },

    {
      "id": "performance-section",
      "check": "section_exists",
      "pattern": "^## Performance Summary",
      "required": true
    },
    {
      "id": "performance-table",
      "check": "table_has_columns",
      "section": "Performance Summary",
      "columns": ["Metric", "Value"],
      "minRows": 3,
      "required": true
    },
    {
      "id": "metric-cagr",
      "check": "metric_exists",
      "section": "Performance Summary",
      "metric": "CAGR",
      "required": true
    },
    {
      "id": "metric-volatility",
      "check": "metric_exists",
      "section": "Performance Summary",
      "metric": "Volatility",
      "required": true
    },
    {
      "id": "metric-sharpe",
      "check": "metric_exists",
      "section": "Performance Summary",
      "metric": "Sharpe",
      "required": true
    },
    {
      "id": "metric-max-dd",
