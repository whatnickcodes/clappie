#!/usr/bin/env node
/**
 * playwright-login.js
 *
 * Logs into backtes.to using Playwright with persistent browser context.
 * Reads credentials from ~/.backtesto/credentials.json
 *
 * Auth model: Session-based (NOT localStorage). Login is via Account modal
 * (click account-button, fill #username/#password). Login state is detected
 * visually by checking if the modal shows "LOGOUT" text vs login form.
 *
 * Note: Login is NOT required for basic backtesting, only for saving portfolios.
 *
 * Exit codes:
 *   0 = success (already logged in or login succeeded)
 *   1 = auth failed (bad credentials)
 *   2 = site unreachable
 */

const { chromium } = require('playwright');
const fs = require('fs');
const path = require('path');
const os = require('os');

const CREDS_PATH = path.join(os.homedir(), '.backtesto', 'credentials.json');
const BROWSER_DATA = path.join(os.homedir(), '.backtesto', 'browser-data');
const BASE_URL = 'https://backtes.to';

async function checkLoginState(page) {
  // Open Account modal
  const accountBtn = await page.$('#account-button');
  if (!accountBtn) {
    return { loggedIn: false, error: 'account-button not found' };
  }
  await accountBtn.click();
  await page.waitForTimeout(2000);

  // Check login state visually
  const state = await page.evaluate(() => {
    const modal = document.querySelector('#login-modal');
    if (!modal) return { loggedIn: false, modalFound: false };
    const hasLogout = modal.innerText.includes('LOGOUT');
    const hasLoginForm = !!modal.querySelector('#username');
    return { loggedIn: hasLogout, hasLoginForm, modalFound: true };
  });

  // Close modal
  await page.keyboard.press('Escape');
  await page.waitForTimeout(500);

  return state;
}

async function main() {
  // Read credentials
  if (!fs.existsSync(CREDS_PATH)) {
    console.error(JSON.stringify({ error: 'Credentials not found', path: CREDS_PATH }));
    process.exit(1);
  }

  const creds = JSON.parse(fs.readFileSync(CREDS_PATH, 'utf-8'));
  if (!creds.email || !creds.password) {
    console.error(JSON.stringify({ error: 'Invalid credentials file: missing email or password' }));
    process.exit(1);
  }

  // Ensure browser data directory exists
  fs.mkdirSync(BROWSER_DATA, { recursive: true });

  let context;
  try {
    context = await chromium.launchPersistentContext(BROWSER_DATA, {
      headless: true,
      viewport: { width: 1280, height: 800 },
    });
  } catch (err) {
    console.error(JSON.stringify({ error: 'Cannot launch browser', details: err.message }));
    process.exit(2);
  }

  const page = context.pages()[0] || await context.newPage();

  try {
    // Navigate to site
    const response = await page.goto(`${BASE_URL}/backtester`, { timeout: 15000 });
    if (!response || !response.ok()) {
      console.error(JSON.stringify({ error: 'Site unreachable', status: response?.status() }));
      await context.close();
      process.exit(2);
    }
    await page.waitForTimeout(3000);

    // Check if already logged in via Account modal
    const state = await checkLoginState(page);

    if (state.loggedIn) {
      console.log(JSON.stringify({ status: 'already_logged_in' }));
      await context.close();
      process.exit(0);
    }

    if (!state.modalFound) {
      console.error(JSON.stringify({ error: 'Login modal not found. Site structure may have changed.' }));
      await context.close();
      process.exit(2);
    }

    // Open Account modal again for login
    const accountBtn = await page.$('#account-button');
    await accountBtn.click();
    await page.waitForTimeout(2000);

    // Fill credentials in modal form
    const emailInput = await page.$('#username');
    const passwordInput = await page.$('#password');

    if (!emailInput || !passwordInput) {
      console.error(JSON.stringify({
        error: 'Cannot find login inputs (#username / #password)',
        hint: 'Element IDs may have changed. Run discovery.',
      }));
      await context.close();
      process.exit(1);
    }

    await emailInput.fill(creds.email);
    await passwordInput.fill(creds.password);

    // Submit - press Enter (the form submits on Enter)
    await page.keyboard.press('Enter');
    await page.waitForTimeout(4000);

    // Verify login succeeded - check for LOGOUT text in modal
    const loginSuccess = await page.evaluate(() => {
      const modal = document.querySelector('#login-modal');
      if (!modal) return false;
      return modal.innerText.includes('LOGOUT');
    });

    // Close modal
    await page.keyboard.press('Escape');
    await page.waitForTimeout(500);

    if (loginSuccess) {
      console.log(JSON.stringify({ status: 'login_success' }));
      await context.close();
      process.exit(0);
    } else {
      console.error(JSON.stringify({ error: 'Login failed - credentials may be incorrect' }));
      await context.close();
      process.exit(1);
    }
  } catch (err) {
    console.error(JSON.stringify({ error: 'Login error', details: err.message }));
    await context.close();
    process.exit(2);
  }
}

main();
